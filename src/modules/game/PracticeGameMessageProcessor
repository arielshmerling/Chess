
const { MessageProcessor } = require("./MessageProcessor");

class PracticeGameMessageProcessor extends MessageProcessor {

    infoTypeHandlers = {
        "move accepted": null,
        "resign": this.resign,
        "offer draw": null,
        "draw accepted": null,
        "draw declined": null,
        "offer rematch": null,
        "rematch accepted": null,
        "rematch declined": null,
        "outOfTime": null,
    };

    onInfoReceived(game, msg) {
        if (game?.messageProcessor.infoTypeHandlers[msg.info] != null) {
            const infoHandler = game.messageProcessor.infoTypeHandlers[msg.info];
            if (infoHandler) { infoHandler(game, msg); }
        }
    }

    async onMoveReceived(game, msg) {
        if (!msg.data) { return; }
        await game.handleMove(msg.isWhite, msg.data, "player");
    }

    resign(game, msg) {
        const resignedPlayer = msg.isWhite ? "White" : "Black";
        game.resign(resignedPlayer);
    }
}

module.exports = { PracticeGameMessageProcessor };