<% layout("../views/layouts/boilerplate") %>

<link rel="stylesheet" href="/welcome.css">
<script>
  window.__LAST_GAME_OPTIONS__ = window.__LAST_GAME_OPTIONS__ || {};
</script>

<!-- <div id="gameBar" class="gameBar">
        <div class="gameBarElement">AI Vs. Ariel</div>
        <div class="gameBarElement"></div>
        <div class="gameBarElement"></div>
    </div> -->

<div id="main" data-initial-game-id="<%= typeof gameId !== 'undefined' && gameId != null ? gameId : '' %>">
  <div id="bookmarksPanel" class="bookmarksPanel">
    <div class="panelHeader">
      <div>
        <h1>Bookmarks</h1>
      </div>
      <div>
        <a href="#"><img src="images/x.png" onclick="closeBookmarkPanel()" class="xButton"></a>
      </div>

    </div>
    <button class="button" onclick="addBookmark()">Bookmark</button>
    <div class="bookmarksSeperator"></div>
    <div id="bookmarksList" class="bookmarksList">
      <!--   <div class="bookmark">
        <div>01/01/2025 12:50</div>
        <div>Practice</div>
      </div>

      <div class="bookmark">

      </div> -->
    </div>
    <div class="bookmarksFooter">

    </div>

  </div>
  <div class="controlPanel">
    <div id="blackClock" class="sideBlock clock short blackClock">
      <div id="blackTurnClock" class="turnClock unvisible"><img src="/images/clock.png" width="24" />
      </div>
      <div id="blackClockTimeText">05:00:00</div>

    </div>
    <div id=" blackPlayersInfo" class="sideBlock playerInfo short">
      <div class="dot" id="blackPlayerStatus"></div>
      <div id="blackPlayerName"></div>
      <div id="blackPlayerDiconnectionTimer" class="disconnectionTimer hide"> (60)</div>
    </div>

    <div id="whiteCapturedPiece" class="sideBlock captureToolsList"></div>
    <div>

      <div id="movesDivContainer" class="movesDivContainer">
        <div id="movesDivHeader" class="movesDivHeader">
          <table class="movesTableHeader">
            <tr>
              <th>#</th>
              <th>White</th>
              <th>Black</th>
            </tr>
          </table>
        </div>
        <div id="movesDiv" class="movesDiv">

        </div>
      </div>
      <div id="gameNav" class="gameNav">

      </div>
    </div>
  </div>

  <div class="seperator"></div>

  <div id="chessboard"> </div>

  <div class="seperator"></div>


  <div class="controlPanel">
    <div id="whiteClock" class="sideBlock clock short whiteClock">
      <div id="whiteTurnClock" class="turnClock unvisible"><img src="/images/clock.png" width="24" />
      </div>
      <div id="whiteClockTimeText">05:00:00</div>
    </div>
    <div id="whitePlayersInfo" class="sideBlock playerInfo short">
      <div class="dot" id="whitePlayerStatus"></div>
      <div id="whitePlayerName"></div>
      <div id="whitePlayerDiconnectionTimer" class="disconnectionTimer hide"> (60)</div>
    </div>
    <div id="blackCapturedPiece" class="sideBlock captureToolsList"></div>
    <div class="messagesContainer">
      <!-- <textarea id="messages" class="messages" readonly>                </textarea> -->
      <div id="messages" class="messages"></div>
      <div class="chatSendLine">
        <input type="text" class="chatline" id="chatline" maxlength="30" />
        <img src="/images/whiteSend.png" alt="send" class="sendButton" onclick="onSendChatButtonClick(event)" />
      </div>
    </div>
  </div>

</div>

<section id="options">
</section>

<div id="debugGameId" class="debug-game-id" title="Debug: game identifier">Game ID: <%= typeof gameId !== 'undefined' && gameId != null ? gameId : '(none)' %></div>

  <!-- New game options modal (for Rematch on single player) -->
  <div id="playNowModal" class="play-now-modal" aria-hidden="true">
    <div class="play-now-modal-overlay" onclick="closePlayNowModal()"></div>
    <div class="play-now-modal-dialog" role="dialog" aria-labelledby="playNowModalTitle">
      <h2 id="playNowModalTitle" class="play-now-modal-title">New game</h2>
      <form id="playNowForm" class="play-now-form" onsubmit="startNewGameFromModal(event)">
        <div class="play-now-field">
          <label class="play-now-label">Playing color</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio">
              <input type="radio" name="color" value="white" checked>
              <span>White</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="color" value="black">
              <span>Black</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowEngine">Engine</label>
          <select id="playNowEngine" name="engine" class="play-now-select">
            <option value="brain4">Brain 4.0</option>
            <option value="brain3">Brain 3</option>
            <option value="brain2">Brain 2</option>
            <option value="brain5">Brain 5</option>
          </select>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowDifficulty">Difficulty (1–5)</label>
          <div class="play-now-slider-row">
            <input type="range" min="1" max="5" value="3" name="difficulty" id="playNowDifficulty" class="play-now-slider" oninput="document.getElementById('playNowDifficultyValue').textContent=this.value">
            <span id="playNowDifficultyValue" class="play-now-slider-value">3</span>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label">Mouse preference</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio" id="mouseDragLabel">
              <input type="radio" name="mouse" value="drag" id="mouseDrag" checked>
              <span>Drag</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="mouse" value="double" id="mouseDouble">
              <span>Double click</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-checkbox-label">
            <input type="checkbox" name="showMoves" id="playNowShowMoves" value="1" checked>
            <span>Show available moves</span>
          </label>
        </div>
        <div class="play-now-modal-actions">
          <button type="button" class="play-now-btn-cancel" onclick="closePlayNowModal()">Cancel</button>
          <button type="submit" class="play-now-btn-start">Start</button>
        </div>
      </form>
    </div>
  </div>