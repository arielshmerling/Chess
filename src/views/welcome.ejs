<% layout("../views/layouts/boilerplate") %>

<link rel="stylesheet" href="/welcome.css">
<script>
  window.__LAST_GAME_OPTIONS__ = <%- JSON.stringify(typeof lastGameOptions !== "undefined" && lastGameOptions ? lastGameOptions : {}) %>;
</script>

<div class="welcome-container">
  <!-- Hero Banner with Chess Theme -->
  <div class="hero-banner">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-logo">
        <img src="/images/logo_chess.png" alt="Shmerling Chess Club" class="hero-logo-img">
      </div>
      <div class="hero-text-section">
        <h1 class="hero-greeting">Welcome Back</h1>
        <h2 class="hero-username"><%=username %></h2>
        <p class="hero-tagline">Your move awaits</p>
      </div>
      <div class="hero-right">
        <div class="hero-chess-icon">
          <div class="chess-pieces-container">
            <!-- <span class="chess-piece-symbol king-symbol">♔</span> -->
          </div>
        </div>
        <div class="hero-play-now">
          <button type="button" class="play-now-btn" id="startAIGame" onclick="openPlayNowModal()">Play Now!</button>
        </div>
      </div>
    </div>
  </div>

  <!-- New game options modal -->
  <div id="playNowModal" class="play-now-modal" aria-hidden="true">
    <div class="play-now-modal-overlay" onclick="closePlayNowModal()"></div>
    <div class="play-now-modal-dialog" role="dialog" aria-labelledby="playNowModalTitle">
      <h2 id="playNowModalTitle" class="play-now-modal-title">Start a new Game</h2>
      <form id="playNowForm" class="play-now-form" onsubmit="startNewGameFromModal(event)">
        <div class="play-now-field">
          <label class="play-now-label">Playing color</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio">
              <input type="radio" name="color" value="white" checked>
              <span>White</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="color" value="black">
              <span>Black</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowEngine">Engine</label>
          <select id="playNowEngine" name="engine" class="play-now-select">
            <option value="brain4">Brain 4.0</option>
            <option value="brain3">Brain 3</option>
            <option value="brain2">Brain 2</option>
            <option value="brain5">Brain 5</option>
          </select>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowDifficulty">Difficulty (1–5)</label>
          <div class="play-now-slider-row">
            <input type="range" min="1" max="5" value="3" name="difficulty" id="playNowDifficulty" class="play-now-slider" oninput="document.getElementById('playNowDifficultyValue').textContent=this.value">
            <span id="playNowDifficultyValue" class="play-now-slider-value">3</span>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label">Mouse preference</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio" id="mouseDragLabel">
              <input type="radio" name="mouse" value="drag" id="mouseDrag" checked>
              <span>Drag</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="mouse" value="double" id="mouseDouble">
              <span>Double click</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-checkbox-label">
            <input type="checkbox" name="showMoves" id="playNowShowMoves" value="1" checked>
            <span>Show available moves</span>
          </label>
        </div>
        <div class="play-now-modal-actions">
          <button type="button" class="play-now-btn-cancel" onclick="closePlayNowModal()">Cancel</button>
          <button type="submit" class="play-now-btn-start">Start</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Games Section -->
  <div class="games-section">
    <!-- Online Games -->
    <div class="games-panel online-games-panel">
      <div class="panel-header">
        <div class="panel-title-group">
          <h3 class="panel-title">Online Games</h3>
          <span class="panel-badge">Live</span>
        </div>
        <div class="panel-subtitle">Active matches in progress</div>
      </div>
      <div class="panel-body">
        <% if(allGames && allGames.length > 0) { %>
        <div class="table-scroll">
          <table class="games-table">
            <thead>
              <tr>
                <th>#</th>
                <%obj=allGames[0];i=1%>
                <% for(const key in obj) { %>
                <% if(key !="Id" ) { %>
                <th><%=key %></th>
                <% } %>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% for(const obj of allGames){ %>
              <tr onclick=<%-`"window.location='/watch?id=${obj.Id}'"`%>>
                <td class="row-number"><%=i++ %></td>
                <% for(const key in obj) { %>
                <% if(key != 'Id' ) { %>
                <td class="<%=key==' Reason' ? 'align-left' : '' %>" onclick=<%-`"window.location='/watch?id=${obj.Id}'"`%>>
                  <%= obj[key] %>
                </td>
                <% } %>
                <% } %>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="no-games-message">
          <p>No games at the moment</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- My Games -->
    <div class="games-panel my-games-panel">
      <div class="panel-header">
        <div class="panel-title-group">
          <h3 class="panel-title">My Games</h3>
        </div>
        <div class="panel-subtitle">Your recent completed games</div>
      </div>
      <div class="panel-body">
        <% if(playerGames && playerGames.length > 0) { %>
        <div class="table-scroll compact">
          <table class="games-table sortable">
            <thead>
              <tr>
                <th class="sortable-th" data-sort-key="rowIndex" title="Sort by row number">
                  <span class="th-label">#</span>
                  <span class="sort-icon" aria-hidden="true"></span>
                </th>
                <% obj = playerGames[0]; %>
                <% for(const key in obj) { %>
                  <% if(key !== "Id" && !key.startsWith("_")) { %>
                <th class="sortable-th" data-sort-key="<%= key.replace(/^\s+/, '').replace(/\s+$/, '') %>" title="Sort by <%= key.trim() %>">
                  <span class="th-label"><%= key %></span>
                  <span class="sort-icon" aria-hidden="true"></span>
                </th>
                  <% } %>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% rowIndex = 0; for(const obj of playerGames) { %>
              <tr data-row-index="<%= rowIndex %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                <td class="row-number sortable-td" data-sort-key="rowIndex" data-sort-value="<%= rowIndex %>"><%= rowIndex + 1 %></td>
                <% for(const key in obj) { %>
                  <% if(key !== 'Id' && !key.startsWith('_')) { %>
                    <% sortVal = key === 'Date' ? (obj._sortableDate != null ? obj._sortableDate : 0) : (key === 'Moves' ? (obj.Moves != null ? obj.Moves : 0) : (obj[key] != null ? String(obj[key]).replace(/"/g, '&quot;') : '')); %>
                <td class="<%= key.trim() === 'Reason' ? 'align-left ' : '' %>sortable-td" data-sort-key="<%= key.trim() %>" data-sort-value="<%= sortVal %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                  <%= obj[key] %>
                </td>
                  <% } %>
                <% } %>
              </tr>
              <% rowIndex++; } %>
            </tbody>
          </table>
        </div>
        <script>
(function() {
    var table = document.querySelector('.my-games-panel table.sortable');
    if (!table) return;
    var thead = table.querySelector('thead tr');
    var tbody = table.querySelector('tbody');
    var sortState = { key: null, asc: true };
    function getSortValue(cell) {
        var key = cell.getAttribute('data-sort-key');
        var raw = cell.getAttribute('data-sort-value');
        if (key === 'rowIndex' || key === 'Date' || key === 'Moves') return Number(raw) || 0;
        return raw;
    }
    function compare(a, b) {
        var na = typeof a === 'number', nb = typeof b === 'number';
        if (na && nb) return a - b;
        if (na) return -1;
        if (nb) return 1;
        return String(a).localeCompare(String(b));
    }
    thead.addEventListener('click', function(ev) {
        var th = ev.target.closest('th.sortable-th');
        if (!th) return;
        ev.preventDefault();
        var key = th.getAttribute('data-sort-key');
        if (sortState.key === key) sortState.asc = !sortState.asc;
        else { sortState.key = key; sortState.asc = true; }
        var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
        rows.sort(function(ra, rb) {
            var ca = ra.querySelector('td[data-sort-key="' + key + '"]');
            var cb = rb.querySelector('td[data-sort-key="' + key + '"]');
            if (!ca || !cb) return 0;
            var va = getSortValue(ca), vb = getSortValue(cb);
            var cmp = compare(va, vb);
            return sortState.asc ? cmp : -cmp;
        });
        rows.forEach(function(r) { tbody.appendChild(r); });
        rows.forEach(function(r, i) {
            var numCell = r.querySelector('td[data-sort-key="rowIndex"]');
            if (numCell) { numCell.setAttribute('data-sort-value', i); numCell.textContent = i + 1; }
        });
        thead.querySelectorAll('.sort-icon').forEach(function(icon) { icon.textContent = ''; icon.classList.remove('asc', 'desc'); });
        var activeIcon = th.querySelector('.sort-icon');
        if (activeIcon) {
            activeIcon.textContent = sortState.asc ? '\u25B2' : '\u25BC';
            activeIcon.classList.add(sortState.asc ? 'asc' : 'desc');
        }
    });
})();
        </script>
        <% } else { %>
        <div class="no-games-message">
          <p>No completed games yet</p>
        </div>
        <% } %>
        <div class="panel-footer">
          <a href="/list" class="footer-link">
            <span>View All Games</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
