<% layout("../views/layouts/boilerplate") %>

<link rel="stylesheet" href="/welcome.css">

<div class="welcome-container">
  <!-- Hero Banner with Chess Theme -->
  <div class="hero-banner">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-logo">
        <img src="/images/logo_chess.png" alt="Shmerling Chess Club" class="hero-logo-img">
      </div>
      <div class="hero-text-section">
        <h1 class="hero-greeting">Welcome Back</h1>
        <h2 class="hero-username"><%=username %></h2>
        <p class="hero-tagline">Your move awaits</p>
      </div>
      <div class="hero-chess-icon">
        <div class="chess-pieces-container">
          <!-- <span class="chess-piece-symbol king-symbol">♔</span> -->
        
        </div>
      </div>
    </div>
  </div>

  <!-- Play now - single primary action; opens options modal -->
  <div class="play-now-section">
    <button type="button" class="play-now-btn" id="startAIGame" onclick="openPlayNowModal()">Play Now!</button>
  </div>

  <!-- New game options modal -->
  <div id="playNowModal" class="play-now-modal" aria-hidden="true">
    <div class="play-now-modal-overlay" onclick="closePlayNowModal()"></div>
    <div class="play-now-modal-dialog" role="dialog" aria-labelledby="playNowModalTitle">
      <h2 id="playNowModalTitle" class="play-now-modal-title">Start a new Game</h2>
      <form id="playNowForm" class="play-now-form" onsubmit="startNewGameFromModal(event)">
        <div class="play-now-field">
          <label class="play-now-label">Playing color</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio">
              <input type="radio" name="color" value="white" checked>
              <span>White</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="color" value="black">
              <span>Black</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowEngine">Engine</label>
          <select id="playNowEngine" name="engine" class="play-now-select">
            <option value="brain4">Brain 4.0</option>
            <option value="brain3">Brain 3</option>
            <option value="brain2">Brain 2</option>
            <option value="brain5">Brain 5</option>
          </select>
        </div>
        <div class="play-now-field">
          <label class="play-now-label" for="playNowDifficulty">Difficulty (1–5)</label>
          <div class="play-now-slider-row">
            <input type="range" min="1" max="5" value="3" name="difficulty" id="playNowDifficulty" class="play-now-slider" oninput="document.getElementById('playNowDifficultyValue').textContent=this.value">
            <span id="playNowDifficultyValue" class="play-now-slider-value">3</span>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-label">Mouse preference</label>
          <div class="play-now-radio-group">
            <label class="play-now-radio" id="mouseDragLabel">
              <input type="radio" name="mouse" value="drag" id="mouseDrag" checked>
              <span>Drag</span>
            </label>
            <label class="play-now-radio">
              <input type="radio" name="mouse" value="double" id="mouseDouble">
              <span>Double click</span>
            </label>
          </div>
        </div>
        <div class="play-now-field">
          <label class="play-now-checkbox-label">
            <input type="checkbox" name="showMoves" id="playNowShowMoves" value="1" checked>
            <span>Show available moves</span>
          </label>
        </div>
        <div class="play-now-modal-actions">
          <button type="button" class="play-now-btn-cancel" onclick="closePlayNowModal()">Cancel</button>
          <button type="submit" class="play-now-btn-start">Start</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Games Section -->
  <div class="games-section">
    <!-- Online Games -->
    <div class="games-panel online-games-panel">
      <div class="panel-header">
        <div class="panel-title-group">
          <h3 class="panel-title">Online Games</h3>
          <span class="panel-badge">Live</span>
        </div>
        <div class="panel-subtitle">Active matches in progress</div>
      </div>
      <div class="panel-body">
        <% if(allGames && allGames.length > 0) { %>
        <div class="table-scroll">
          <table class="games-table">
            <thead>
              <tr>
                <th>#</th>
                <%obj=allGames[0];i=1%>
                <% for(const key in obj) { %>
                <% if(key !="Id" ) { %>
                <th><%=key %></th>
                <% } %>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% for(const obj of allGames){ %>
              <tr onclick=<%-`"window.location='/watch?id=${obj.Id}'"`%>>
                <td class="row-number"><%=i++ %></td>
                <% for(const key in obj) { %>
                <% if(key != 'Id' ) { %>
                <td class="<%=key==' Reason' ? 'align-left' : '' %>" onclick=<%-`"window.location='/watch?id=${obj.Id}'"`%>>
                  <%= obj[key] %>
                </td>
                <% } %>
                <% } %>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="no-games-message">
          <p>No games at the moment</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- My Games -->
    <div class="games-panel my-games-panel">
      <div class="panel-header">
        <div class="panel-title-group">
          <h3 class="panel-title">My Games</h3>
        </div>
        <div class="panel-subtitle">Your recent matches</div>
      </div>
      <div class="panel-body">
        <% if(playerGames && playerGames.length > 0) { %>
        <div class="table-scroll compact">
          <table class="games-table">
            <thead>
              <tr>
                <th>#</th>
                <%obj=playerGames[0];i=1%>
                <% for(const key in obj) { %>
                <% if(key !="Id" ) { %>
                <th><%=key %></th>
                <% } %>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% for(const obj of playerGames){ %>
              <tr onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                <td class="row-number"><%=i++ %></td>
                <% for(const key in obj) { %>
                <% if(key != 'Id' ) { %>
                <td class="<%=key==' Reason' ? 'align-left' : '' %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                  <%= obj[key] %>
                </td>
                <% } %>
                <% } %>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="no-games-message">
          <p>No games at the moment</p>
        </div>
        <% } %>
        <div class="panel-footer">
          <a href="/list" class="footer-link">
            <span>View All Games</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
