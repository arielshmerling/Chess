<% layout("../views/layouts/boilerplate") %>

    <section id="PlayerGameList">
        <br><br><br><br>
        <h1>All Games</h1>
        <br><br>
        <% if (playerGames && playerGames.length > 0) { %>
        <div class="gamesTableContainer">
            <table class="gamesTable sortable">
                <thead>
                <tr>
                    <th class="sortable-th" data-sort-key="rowIndex" title="Sort by row number">
                        <span class="th-label">#</span>
                        <span class="sort-icon" aria-hidden="true"></span>
                    </th>
                    <% obj = playerGames[0]; %>
                    <% for(const key in obj) { %>
                        <% if(key !== "Id" && !key.startsWith("_")) { %>
                    <th class="sortable-th" data-sort-key="<%= key.replace(/^\s+/, '').replace(/\s+$/, '') %>" title="Sort by <%= key.trim() %>">
                        <span class="th-label"><%= key %></span>
                        <span class="sort-icon" aria-hidden="true"></span>
                    </th>
                        <% } %>
                    <% } %>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                <% rowIndex = 0; for(const obj of playerGames) { %>
                    <tr data-row-index="<%= rowIndex %>">
                        <td class="sortable-td" data-sort-key="rowIndex" data-sort-value="<%= rowIndex %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>><%= rowIndex + 1 %></td>
                        <% for(const key in obj) { %>
                            <% if(key !== 'Id' && !key.startsWith('_')) { %>
                                <% sortVal = key === 'Date' ? (obj._sortableDate || 0) : (key === 'Moves' ? (obj.Moves || 0) : (obj[key] != null ? String(obj[key]).replace(/"/g, '&quot;') : '')); %>
                                <% if(key.trim() === "Reason") { %>
                        <td class="alignLeft sortable-td" data-sort-key="<%= key.trim() %>" data-sort-value="<%= sortVal %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                                <% } else { %>
                            <td class="sortable-td" data-sort-key="<%= key.trim() %>" data-sort-value="<%= sortVal %>" onclick=<%-`"window.location='/review?type=history&id=${obj.Id}'"`%>>
                                <% } %>
                                    <%= obj[key] %>
                            </td>
                            <% } %>
                        <% } %>
                        <td class="no-sort">
                            <form action="/list/<%= obj.Id %>?_method=delete" method="POST">
                                <a href="javascript:{}" onclick="this.closest('form').submit();return false;">Delete</a>
                            </form>
                        </td>
                    </tr>
                <% rowIndex++; } %>
                </tbody>
            </table>
        </div>
        <script>
(function() {
    var table = document.querySelector('#PlayerGameList table.sortable');
    if (!table) return;
    var thead = table.querySelector('thead tr');
    var tbody = table.querySelector('tbody');
    var sortState = { key: null, asc: true };

    function getSortValue(cell) {
        var key = cell.getAttribute('data-sort-key');
        var raw = cell.getAttribute('data-sort-value');
        if (key === 'rowIndex' || key === 'Date' || key === 'Moves') return Number(raw) || 0;
        return raw;
    }

    function compare(a, b) {
        var na = typeof a === 'number', nb = typeof b === 'number';
        if (na && nb) return a - b;
        if (na) return -1;
        if (nb) return 1;
        return String(a).localeCompare(String(b));
    }

    thead.addEventListener('click', function(ev) {
        var th = ev.target.closest('th.sortable-th');
        if (!th) return;
        ev.preventDefault();
        var key = th.getAttribute('data-sort-key');
        if (sortState.key === key) sortState.asc = !sortState.asc;
        else { sortState.key = key; sortState.asc = true; }

        var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
        rows.sort(function(ra, rb) {
            var ca = ra.querySelector('td[data-sort-key="' + key + '"]');
            var cb = rb.querySelector('td[data-sort-key="' + key + '"]');
            if (!ca || !cb) return 0;
            var va = getSortValue(ca), vb = getSortValue(cb);
            var cmp = compare(va, vb);
            return sortState.asc ? cmp : -cmp;
        });
        rows.forEach(function(r) { tbody.appendChild(r); });
        rows.forEach(function(r, i) {
            var numCell = r.querySelector('td[data-sort-key="rowIndex"]');
            if (numCell) { numCell.setAttribute('data-sort-value', i); numCell.textContent = i + 1; }
        });

        thead.querySelectorAll('.sort-icon').forEach(function(icon) { icon.textContent = ''; icon.classList.remove('asc', 'desc'); });
        var activeIcon = th.querySelector('.sort-icon');
        if (activeIcon) {
            activeIcon.textContent = sortState.asc ? '\u25B2' : '\u25BC';
            activeIcon.classList.add(sortState.asc ? 'asc' : 'desc');
        }
    });
})();
        </script>
        <% } else { %>
        <div class="no-games-message">
            <p>No completed games yet</p>
        </div>
        <% } %>
    </section>
    <br><br>